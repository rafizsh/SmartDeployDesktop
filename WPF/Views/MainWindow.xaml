<Window x:Class="SmartDeployDesktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SmartDeployDesktop.ViewModels"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="SmartDeploy Desktop" Width="1280" Height="820" MinWidth="960" MinHeight="640"
        WindowStartupLocation="CenterScreen" Background="{StaticResource BgBase}"
        TextElement.Foreground="{StaticResource TextPrimary}" FontFamily="Segoe UI">
    <Window.DataContext><vm:MainViewModel/></Window.DataContext>
    <Window.Resources>
        <Style x:Key="HoverRow" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#252537"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/><ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="#181825" BorderBrush="#313244" BorderThickness="0,0,1,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="16,20,16,24">
                    <TextBlock Text="SmartDeploy" FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentBlue}"/>
                    <TextBlock Text="Desktop Edition" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                </StackPanel>
                <Border DockPanel.Dock="Bottom" Margin="12,0,12,16" Padding="10,8" CornerRadius="6" Background="#11111B">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                                <Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="{StaticResource AccentRed}"/>
                                    <Style.Triggers><DataTrigger Binding="{Binding IsServerConnected}" Value="True"><Setter Property="Fill" Value="{StaticResource AccentGreen}"/></DataTrigger></Style.Triggers>
                                </Style></Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding ServerStatus}" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="16,4,0,0">
                            <Ellipse Width="6" Height="6" Fill="{Binding Services.DhcpDotColor}" Margin="0,0,3,0"/>
                            <TextBlock Text="DHCP" FontSize="9" Foreground="{StaticResource TextMuted}" Margin="0,0,8,0"/>
                            <Ellipse Width="6" Height="6" Fill="{Binding Services.TftpDotColor}" Margin="0,0,3,0"/>
                            <TextBlock Text="TFTP" FontSize="9" Foreground="{StaticResource TextMuted}" Margin="0,0,8,0"/>
                            <Ellipse Width="6" Height="6" Fill="{Binding Services.ApiDotColor}" Margin="0,0,3,0"/>
                            <TextBlock Text="API" FontSize="9" Foreground="{StaticResource TextMuted}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <StackPanel Margin="8,0">
                    <TextBlock Text="OVERVIEW" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" Margin="12,0,0,6"/>
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="Dashboard" HorizontalContentAlignment="Left" Height="36" Padding="12,0" Margin="0,1">
                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}"><Setter Property="Foreground" Value="{StaticResource TextSecondary}"/><Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers><DataTrigger Binding="{Binding IsDashboardPage}" Value="True"><Setter Property="Background" Value="#313244"/><Setter Property="Foreground" Value="{StaticResource AccentBlue}"/></DataTrigger></Style.Triggers>
                        </Style></Button.Style>
                        <TextBlock Text="▦  Dashboard"/>
                    </Button>
                    <TextBlock Text="IMAGING" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" Margin="12,16,0,6"/>
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="Images" HorizontalContentAlignment="Left" Height="36" Padding="12,0" Margin="0,1">
                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}"><Setter Property="Foreground" Value="{StaticResource TextSecondary}"/><Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers><DataTrigger Binding="{Binding IsImagesPage}" Value="True"><Setter Property="Background" Value="#313244"/><Setter Property="Foreground" Value="{StaticResource AccentBlue}"/></DataTrigger></Style.Triggers>
                        </Style></Button.Style>
                        <TextBlock Text="💿  WIM Images"/>
                    </Button>
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="TaskSequences" HorizontalContentAlignment="Left" Height="36" Padding="12,0" Margin="0,1">
                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}"><Setter Property="Foreground" Value="{StaticResource TextSecondary}"/><Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers><DataTrigger Binding="{Binding IsTaskSequencesPage}" Value="True"><Setter Property="Background" Value="#313244"/><Setter Property="Foreground" Value="{StaticResource AccentBlue}"/></DataTrigger></Style.Triggers>
                        </Style></Button.Style>
                        <TextBlock Text="📋  Task Sequences"/>
                    </Button>
                    <TextBlock Text="NETWORK" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" Margin="12,16,0,6"/>
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="Deployments" HorizontalContentAlignment="Left" Height="36" Padding="12,0" Margin="0,1">
                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}"><Setter Property="Foreground" Value="{StaticResource TextSecondary}"/><Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers><DataTrigger Binding="{Binding IsDeploymentsPage}" Value="True"><Setter Property="Background" Value="#313244"/><Setter Property="Foreground" Value="{StaticResource AccentBlue}"/></DataTrigger></Style.Triggers>
                        </Style></Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🖥  Deployments"/>
                            <Border Background="{StaticResource AccentCyan}" CornerRadius="8" Padding="6,1" Margin="8,0,0,0"
                                    Visibility="{Binding ActiveDeployCount, Converter={StaticResource StringToVisibilityConverter}}">
                                <TextBlock Text="{Binding ActiveDeployCount}" FontSize="10" FontWeight="Bold" Foreground="#1e1e2e"/>
                            </Border>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="Services" HorizontalContentAlignment="Left" Height="36" Padding="12,0" Margin="0,1">
                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}"><Setter Property="Foreground" Value="{StaticResource TextSecondary}"/><Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers><DataTrigger Binding="{Binding IsServicesPage}" Value="True"><Setter Property="Background" Value="#313244"/><Setter Property="Foreground" Value="{StaticResource AccentBlue}"/></DataTrigger></Style.Triggers>
                        </Style></Button.Style>
                        <TextBlock Text="🖧  Services"/>
                    </Button>
                    <TextBlock Text="CONFIGURATION" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" Margin="12,16,0,6"/>
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="Settings" HorizontalContentAlignment="Left" Height="36" Padding="12,0" Margin="0,1">
                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}"><Setter Property="Foreground" Value="{StaticResource TextSecondary}"/><Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers><DataTrigger Binding="{Binding IsSettingsPage}" Value="True"><Setter Property="Background" Value="#313244"/><Setter Property="Foreground" Value="{StaticResource AccentBlue}"/></DataTrigger></Style.Triggers>
                        </Style></Button.Style>
                        <TextBlock Text="🔧  Settings"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>
        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/><RowDefinition Height="*"/><RowDefinition Height="32"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#181825" BorderBrush="#313244" BorderThickness="0,0,0,1">
                <DockPanel Margin="20,0">
                    <TextBlock Text="{Binding CurrentPage}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right" Content="↻ Refresh" Command="{Binding RefreshCurrentPageCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{StaticResource AccentCyan}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </DockPanel>
            </Border>

            <!-- DASHBOARD -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16" DataContext="{Binding Dashboard}"
                          Visibility="{Binding DataContext.IsDashboardPage, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <UniformGrid Columns="4" Margin="0,0,0,16">
                        <Border Style="{StaticResource CardStyle}"><StackPanel>
                            <TextBlock Text="WIM Images" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                            <TextBlock Text="{Binding Stats.TotalImages}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentBlue}"/>
                            <TextBlock Text="{Binding Stats.ImageStoreSize}" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                        </StackPanel></Border>
                        <Border Style="{StaticResource CardStyle}"><StackPanel>
                            <TextBlock Text="Drivers" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                            <TextBlock Text="{Binding Stats.TotalPlatformPacks}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentGreen}"/>
                            <TextBlock Text="{Binding Stats.DriverStoreSize}" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                        </StackPanel></Border>
                        <Border Style="{StaticResource CardStyle}"><StackPanel>
                            <TextBlock Text="Task Sequences" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                            <TextBlock Text="{Binding Stats.TotalTaskSequences}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentYellow}"/>
                        </StackPanel></Border>
                        <Border Style="{StaticResource CardStyle}"><StackPanel>
                            <TextBlock Text="Active Deploys" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                            <TextBlock Text="{Binding Stats.ActiveDeployments}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentCyan}"/>
                        </StackPanel></Border>
                    </UniformGrid>
                    <Border Style="{StaticResource CardStyle}"><StackPanel>
                        <TextBlock Text="Active Deployments" Style="{StaticResource SectionHeader}"/>
                        <ItemsControl ItemsSource="{Binding DataContext.Deployments.Clients, RelativeSource={RelativeSource AncestorType=Window}}">
                            <ItemsControl.ItemTemplate><DataTemplate>
                                <Border Padding="10,8" Margin="0,2" CornerRadius="4" Background="#11111B">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/><ColumnDefinition Width="55"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Mac}" Foreground="{StaticResource AccentCyan}" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Ip}" Foreground="{StaticResource TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="2" Margin="8,0">
                                            <TextBlock Text="{Binding CurrentStep}" Foreground="{StaticResource TextPrimary}" FontSize="11" Margin="0,0,0,3"/>
                                            <Border Background="#313244" CornerRadius="3" Height="8">
                                                <Border CornerRadius="3" HorizontalAlignment="Left" Background="{StaticResource AccentBlue}"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Grid.Column="3" Text="{Binding Progress, StringFormat='{}{0}%'}" Foreground="{StaticResource AccentBlue}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel></Border>
                    <Border Style="{StaticResource CardStyle}"><StackPanel>
                        <TextBlock Text="Recent Activity" Style="{StaticResource SectionHeader}"/>
                        <Border Background="#11111B" CornerRadius="4" MaxHeight="300"><ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding RecentLogs}"><ItemsControl.ItemTemplate><DataTemplate>
                                <TextBlock FontFamily="Consolas" FontSize="11" Padding="6,2">
                                    <Run Text="{Binding Timestamp, Mode=OneWay}" Foreground="{StaticResource TextMuted}"/>
                                    <Run Text=" "/><Run Text="{Binding Level, Mode=OneWay}" Foreground="{StaticResource AccentYellow}"/>
                                    <Run Text=" "/><Run Text="{Binding Message, Mode=OneWay}" Foreground="{StaticResource TextPrimary}"/>
                                </TextBlock>
                            </DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                        </ScrollViewer></Border>
                    </StackPanel></Border>
                </StackPanel>
            </ScrollViewer>

            <!-- IMAGES PAGE -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16" DataContext="{Binding Images}"
                          Visibility="{Binding DataContext.IsImagesPage, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <Border Style="{StaticResource CardStyle}"><StackPanel>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="WIM Image Library" Style="{StaticResource SectionHeader}" DockPanel.Dock="Left"/>
                            <TextBlock Text="C:\SmartDeploy\Images\" Foreground="{StaticResource TextMuted}" FontSize="11" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </DockPanel>
                        <TextBlock Text="{Binding ImageCountText}" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,8"/>
                        <Border Background="#11111B" CornerRadius="4" MaxHeight="300"><ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Images}"><ItemsControl.ItemTemplate><DataTemplate>
                                <Border Padding="12,10" Margin="0,1" CornerRadius="4" Style="{StaticResource HoverRow}">
                                    <Border.InputBindings><MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.SelectImageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}"/></Border.InputBindings>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource AccentBlue}" FontSize="14"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding SizeDisplay}" Foreground="{StaticResource AccentCyan}" FontSize="12" Margin="0,0,12,0"/>
                                                <TextBlock Text="{Binding Format, StringFormat='({0})'}" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding Modified, StringFormat='{}{0:yyyy-MM-dd}'}" Foreground="{StaticResource TextMuted}" FontSize="11" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <Button Grid.Column="2" Content="✕" Command="{Binding DataContext.DeleteImageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{StaticResource AccentRed}" Width="28" Height="28" Padding="0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                        </ScrollViewer></Border>
                        <TextBlock Text="Image Details (click an image above)" Style="{StaticResource SectionHeader}" Margin="0,12,0,4" Visibility="{Binding SelectedImage, Converter={StaticResource NullToVisibilityConverter}}"/>
                        <ItemsControl ItemsSource="{Binding SelectedImageIndexes}"><ItemsControl.ItemTemplate><DataTemplate>
                            <Border Padding="10,6" Margin="0,2" CornerRadius="4" Background="#11111B">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Index, StringFormat='Index {0}:'}" Foreground="{StaticResource AccentYellow}" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimary}" Margin="0,0,12,0"/>
                                    <TextBlock Text="{Binding Size}" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                    </StackPanel></Border>
                    <!-- Driver Injection -->
                    <Border Style="{StaticResource CardStyle}"><StackPanel>
                        <TextBlock Text="Driver Injection" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Inject drivers (.inf) into a WIM image. Mount → Add Drivers → Commit." Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,10"/>
                        <UniformGrid Columns="3" Margin="0,0,0,8">
                            <StackPanel Margin="0,0,6,0"><TextBlock Text="WIM File Path" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding DriverInjectWimPath, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                            <StackPanel Margin="3,0"><TextBlock Text="Driver Folder" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding DriverInjectFolder, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                            <StackPanel Margin="6,0,0,0"><TextBlock Text="Image Index" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding DriverInjectIndex, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                        </UniformGrid>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Button Content="💉 Inject Drivers" Command="{Binding InjectDriversCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Background="{StaticResource AccentBlue}" Foreground="Black" Margin="0,0,8,0" Padding="16,6"/>
                            <Button Content="Use Boot WIM" Command="{Binding UseBootWimCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{StaticResource AccentCyan}" Margin="0,0,8,0"/>
                            <Button Content="Use Selected Image" Command="{Binding UseSelectedImageCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{StaticResource AccentYellow}"/>
                        </StackPanel>
                        <Border Background="#11111B" CornerRadius="4" MaxHeight="200" Margin="0,8,0,0"><ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding DriverInjectLog}"><ItemsControl.ItemTemplate><DataTemplate>
                                <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11" Padding="6,1" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/>
                            </DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                        </ScrollViewer></Border>
                    </StackPanel></Border>
                    <!-- WinPE Setup -->
                    <Border Style="{StaticResource CardStyle}"><StackPanel>
                        <TextBlock Text="WinPE Boot Image Setup" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Inject SmartDeploy startup script + GUI wizard into boot.wim." Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,10"/>
                        <UniformGrid Columns="2" Margin="0,0,0,8">
                            <StackPanel Margin="0,0,6,0"><TextBlock Text="Boot WIM Path" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding WinpeWimPath, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                            <StackPanel Margin="6,0,0,0"><TextBlock Text="Server IP" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding WinpeServerIp, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                        </UniformGrid>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Button Content="💉 Inject WinPE Agent" Command="{Binding InjectWinpeAgentCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Background="{StaticResource AccentGreen}" Foreground="Black" Margin="0,0,8,0" Padding="16,6"/>
                            <Button Content="📂 Create SMB Share" Command="{Binding CreateSmbShareCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{StaticResource AccentCyan}"/>
                        </StackPanel>
                        <Border Background="#11111B" CornerRadius="4" MaxHeight="250" Margin="0,8,0,0"><ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding WinpeInjectLog}"><ItemsControl.ItemTemplate><DataTemplate>
                                <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11" Padding="6,1" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/>
                            </DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                        </ScrollViewer></Border>
                    </StackPanel></Border>
                </StackPanel>
            </ScrollViewer>

            <!-- SETTINGS PAGE -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16" DataContext="{Binding Settings}"
                          Visibility="{Binding DataContext.IsSettingsPage, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel><Border Style="{StaticResource CardStyle}" Padding="0"><DockPanel>
                    <Border DockPanel.Dock="Top" Background="#181825" CornerRadius="8,8,0,0" Padding="4,4,4,0"><WrapPanel>
                        <Button Command="{Binding SwitchTabCommand}" CommandParameter="AD" Margin="2" Padding="10,6" Style="{StaticResource MaterialDesignFlatButton}"><StackPanel Orientation="Horizontal"><Ellipse Width="8" Height="8" Fill="{Binding AdStatusColor}" Margin="0,0,6,0"/><TextBlock Text="AD" Foreground="{StaticResource AccentBlue}"/></StackPanel></Button>
                        <Button Command="{Binding SwitchTabCommand}" CommandParameter="DHCP" Margin="2" Padding="10,6" Style="{StaticResource MaterialDesignFlatButton}"><StackPanel Orientation="Horizontal"><Ellipse Width="8" Height="8" Fill="{Binding DhcpStatusColor}" Margin="0,0,6,0"/><TextBlock Text="DHCP" Foreground="{StaticResource AccentGreen}"/></StackPanel></Button>
                        <Button Command="{Binding SwitchTabCommand}" CommandParameter="TFTP" Margin="2" Padding="10,6" Style="{StaticResource MaterialDesignFlatButton}"><StackPanel Orientation="Horizontal"><Ellipse Width="8" Height="8" Fill="{Binding TftpStatusColor}" Margin="0,0,6,0"/><TextBlock Text="TFTP" Foreground="{StaticResource AccentCyan}"/></StackPanel></Button>
                        <Button Command="{Binding SwitchTabCommand}" CommandParameter="UNC" Margin="2" Padding="10,6" Style="{StaticResource MaterialDesignFlatButton}"><StackPanel Orientation="Horizontal"><Ellipse Width="8" Height="8" Fill="{Binding UncStatusColor}" Margin="0,0,6,0"/><TextBlock Text="UNC" Foreground="{StaticResource AccentYellow}"/></StackPanel></Button>
                        <Button Command="{Binding SwitchTabCommand}" CommandParameter="DB" Margin="2" Padding="10,6" Style="{StaticResource MaterialDesignFlatButton}"><StackPanel Orientation="Horizontal"><Ellipse Width="8" Height="8" Fill="{Binding DbStatusColor}" Margin="0,0,6,0"/><TextBlock Text="Database" Foreground="{StaticResource AccentGreen}"/></StackPanel></Button>
                        <Button Command="{Binding SwitchTabCommand}" CommandParameter="ADMIN" Margin="2" Padding="10,6" Style="{StaticResource MaterialDesignFlatButton}"><StackPanel Orientation="Horizontal"><Ellipse Width="8" Height="8" Fill="{Binding AdminStatusColor}" Margin="0,0,6,0"/><TextBlock Text="Admin" Foreground="{StaticResource AccentYellow}"/></StackPanel></Button>
                    </WrapPanel></Border>
                    <StackPanel Margin="16,12,16,16">
                        <TextBlock Text="{Binding CurrentTabTitle}" Style="{StaticResource SectionHeader}"/>
                        <Border CornerRadius="6" Padding="12,8" Margin="0,0,0,12" Background="{Binding ConnectionStatusBg}"><StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding ConnectionStatusIcon}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <StackPanel><TextBlock Text="{Binding ConnectionStatusText}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" FontSize="13"/><TextBlock Text="{Binding ConnectionStatusDetail}" Foreground="{StaticResource TextMuted}" FontSize="11"/></StackPanel>
                        </StackPanel></Border>
                        <!-- AD --><StackPanel Visibility="{Binding IsAdTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Domain Controller" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding AdDomainController, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                            <TextBlock Text="Domain Name" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding AdDomainName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                            <TextBlock Text="Default OU" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding AdDefaultOu, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                            <TextBlock Text="Join Username" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding AdJoinUser, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                            <TextBlock Text="Join Password" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding AdJoinPassword, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                        </StackPanel>
                        <!-- DHCP --><StackPanel Visibility="{Binding IsDhcpTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="DHCP SCOPE" Foreground="{StaticResource AccentBlue}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Border Background="#11111B" CornerRadius="6" Padding="12" Margin="0,0,0,12"><StackPanel>
                                <TextBlock Text="Server IP" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding ScopeServerIp, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                                <UniformGrid Columns="2"><StackPanel Margin="0,0,6,0"><TextBlock Text="Subnet" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding ScopeSubnet, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/></StackPanel><StackPanel Margin="6,0,0,0"><TextBlock Text="Subnet Mask" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding ScopeSubnetMask, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/></StackPanel></UniformGrid>
                                <UniformGrid Columns="2"><StackPanel Margin="0,0,6,0"><TextBlock Text="Range Start" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding ScopeRangeStart, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/></StackPanel><StackPanel Margin="6,0,0,0"><TextBlock Text="Range End" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding ScopeRangeEnd, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/></StackPanel></UniformGrid>
                                <TextBlock Text="Gateway" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding ScopeGateway, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                                <TextBlock Text="DNS (comma-separated)" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding ScopeDns, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                                <TextBlock Text="Domain" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding ScopeDomain, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                            </StackPanel></Border>
                            <TextBlock Text="PXE BOOT" Foreground="{StaticResource AccentCyan}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Border Background="#11111B" CornerRadius="6" Padding="12" Margin="0,0,0,12"><StackPanel>
                                <TextBlock Text="Boot Server IP" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding ScopeBootServer, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                                <TextBlock Text="Boot File" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding ScopeBootFile, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                            </StackPanel></Border>
                            <TextBlock Text="External DHCP (optional)" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding DhcpServer, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                            <Button Content="📡 Apply DHCP Config" Command="{Binding ApplyDhcpConfigCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Background="{StaticResource AccentGreen}" Foreground="Black" HorizontalAlignment="Left" Padding="16,6"/>
                        </StackPanel>
                        <!-- TFTP --><StackPanel Visibility="{Binding IsTftpTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="TFTP Server" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding TftpServer, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                            <TextBlock Text="Root Path" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding TftpRootPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                            <TextBlock Text="Boot Image Path" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding TftpBootImage, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                            <TextBlock Text="UEFI x64 Boot File" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding TftpBootFileX64, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                            <TextBlock Text="Legacy BIOS Boot File" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding TftpBootFileBios, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                        </StackPanel>
                        <!-- UNC --><StackPanel Visibility="{Binding IsUncTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Images Share" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding UncImageShare, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                            <TextBlock Text="Drivers Share" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding UncDriverShare, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                            <TextBlock Text="Deployment Share" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding UncDeployShare, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                            <TextBlock Text="Logs Share" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding UncLogShare, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                            <TextBlock Text="Username" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding UncUsername, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                            <TextBlock Text="Password" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding UncPassword, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                        </StackPanel>
                        <!-- DB --><StackPanel Visibility="{Binding IsDbTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border Background="#11111B" CornerRadius="6" Padding="12" Margin="0,0,0,12"><StackPanel>
                                <UniformGrid Columns="2"><StackPanel Margin="0,0,6,0"><TextBlock Text="Host" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding DbHost, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/></StackPanel><StackPanel Margin="6,0,0,0"><TextBlock Text="Port" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding DbPort, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/></StackPanel></UniformGrid>
                                <TextBlock Text="Database" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding DbName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                                <UniformGrid Columns="2"><StackPanel Margin="0,0,6,0"><TextBlock Text="User" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding DbUser, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/></StackPanel><StackPanel Margin="6,0,0,0"><TextBlock Text="Password" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding DbPassword, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/></StackPanel></UniformGrid>
                                <TextBlock Text="Postgres Superuser Password" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding DbPostgresPassword, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                            </StackPanel></Border>
                            <TextBlock Text="Config file: %LocalAppData%\SmartDeployDesktop\db_config.json — use Save if PostgreSQL is already installed." Foreground="{StaticResource TextMuted}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Content="💾 Save configuration" Command="{Binding SaveDbConfigCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,8,0" Padding="12,6"/>
                                <Button Content="🐘 Setup PostgreSQL" Command="{Binding SetupPostgresCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Background="{StaticResource AccentGreen}" Foreground="Black" Margin="0,0,8,0" Padding="16,6"/>
                                <Button Content="🔌 Test Connection" Command="{Binding TestDbConnectionCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{StaticResource AccentCyan}"/>
                            </StackPanel>
                            <Border Background="#11111B" CornerRadius="4" MaxHeight="200" Margin="0,4,0,0"><ScrollViewer VerticalScrollBarVisibility="Auto"><ItemsControl ItemsSource="{Binding DbSetupLog}"><ItemsControl.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11" Padding="6,1" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></ScrollViewer></Border>
                        </StackPanel>
                        <!-- Admin --><StackPanel Visibility="{Binding IsAdminTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Credentials written into unattend.xml for deployed machines." Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,12"/>
                            <Border Background="#11111B" CornerRadius="6" Padding="12" Margin="0,0,0,12"><StackPanel>
                                <TextBlock Text="Username" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding AdminUsername, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" FontSize="14"/>
                                <TextBlock Text="Password" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding AdminPassword, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" FontSize="14"/>
                                <TextBlock Text="Timezone" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding AdminTimezone, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                                <TextBlock Text="Locale" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding AdminLocale, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                            </StackPanel></Border>
                            <Button Content="💾 Generate unattend.xml" Command="{Binding GenerateUnattendCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Background="{StaticResource AccentYellow}" Foreground="Black" HorizontalAlignment="Left" Padding="16,6" Margin="0,0,0,8"/>
                            <Border Background="#11111B" CornerRadius="4" MaxHeight="150" Margin="0,4,0,0"><ScrollViewer VerticalScrollBarVisibility="Auto"><ItemsControl ItemsSource="{Binding AdminLog}"><ItemsControl.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11" Padding="6,1" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></ScrollViewer></Border>
                        </StackPanel>
                        <!-- Test Results --><ItemsControl ItemsSource="{Binding TestResults}" Margin="0,4,0,8"><ItemsControl.ItemTemplate><DataTemplate>
                            <Border Padding="10,6" Margin="0,2" CornerRadius="4" Background="#11111B"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontSize="14" VerticalAlignment="Center"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Text" Value="✗"/><Setter Property="Foreground" Value="{StaticResource AccentRed}"/><Style.Triggers><DataTrigger Binding="{Binding Passed}" Value="True"><Setter Property="Text" Value="✓"/><Setter Property="Foreground" Value="{StaticResource AccentGreen}"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                                <TextBlock Grid.Column="1" Text="{Binding Test}" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" FontSize="12"/>
                                <TextBlock Grid.Column="2" Text="{Binding Detail}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" FontSize="11"/>
                            </Grid></Border>
                        </DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                            <Button Content="🔍 Test Connection" Command="{Binding TestConnectionCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{StaticResource AccentCyan}" Margin="0,0,8,0"/>
                            <Button Content="💾 Save" Command="{Binding SaveSettingsCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Background="{StaticResource AccentBlue}" Foreground="Black" Margin="0,0,8,0"/>
                            <Button Content="📂 Reload" Command="{Binding LoadSettingsCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{StaticResource AccentYellow}"/>
                        </StackPanel>
                    </StackPanel>
                </DockPanel></Border></StackPanel>
            </ScrollViewer>

            <!-- TASK SEQUENCES PAGE -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16" DataContext="{Binding TaskSequences}"
                          Visibility="{Binding DataContext.IsTaskSequencesPage, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <Border Style="{StaticResource CardStyle}"><StackPanel>
                        <TextBlock Text="Create Task Sequence" Style="{StaticResource SectionHeader}"/>
                        <UniformGrid Columns="4" Margin="0,0,0,8">
                            <StackPanel Margin="0,0,8,0"><TextBlock Text="Name" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><TextBox Text="{Binding NewTsName, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                            <StackPanel Margin="4,0"><TextBlock Text="Template" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/><ComboBox ItemsSource="{Binding Templates}" SelectedValue="{Binding SelectedTemplate}" SelectedValuePath="Id" DisplayMemberPath="Name"/></StackPanel>
                            <StackPanel Margin="4,0" VerticalAlignment="Bottom"><Button Content="Create" Command="{Binding CreateTaskSequenceCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Background="{StaticResource AccentBlue}" Foreground="Black"/></StackPanel>
                            <StackPanel Margin="8,0,0,0" VerticalAlignment="Bottom"><Button Content="⬇ Import JSON" Command="{Binding ImportTaskSequenceCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="{StaticResource AccentCyan}"/></StackPanel>
                        </UniformGrid>
                    </StackPanel></Border>
                    <Border Style="{StaticResource CardStyle}"><StackPanel>
                        <TextBlock Text="Saved Task Sequences" Style="{StaticResource SectionHeader}"/>
                        <Border Background="#11111B" CornerRadius="4" MaxHeight="400"><ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding TaskSequences}"><ItemsControl.ItemTemplate><DataTemplate>
                                <Border Padding="14,10" Margin="0,2" CornerRadius="4" Style="{StaticResource HoverRow}">
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource AccentYellow}" FontSize="14"/>
                                            <TextBlock Foreground="{StaticResource TextMuted}" FontSize="11"><Run Text="{Binding OsVersion, Mode=OneWay}"/><Run Text=" · "/><Run Text="{Binding Architecture, Mode=OneWay}"/></TextBlock>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding Steps.Count, StringFormat='{}{0} steps', Mode=OneWay}" Foreground="{StaticResource AccentCyan}" VerticalAlignment="Center" Margin="0,0,12,0" FontSize="11"/>
                                        <Button Grid.Column="2" Content="✎ Edit" Command="{Binding DataContext.OpenEditorCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{StaticResource AccentBlue}" Margin="0,0,6,0" Padding="8,2"/>
                                        <Button Grid.Column="3" Content="✕" Command="{Binding DataContext.DeleteTaskSequenceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{StaticResource AccentRed}" Width="28" Height="28" Padding="0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                        </ScrollViewer></Border>
                    </StackPanel></Border>
                </StackPanel>
            </ScrollViewer>

            <!-- DEPLOYMENTS PAGE (merged PXE Status) -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16" DataContext="{Binding Deployments}"
                          Visibility="{Binding DataContext.IsDeploymentsPage, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <Border Style="{StaticResource CardStyle}"><StackPanel>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="PXE Deployments" Style="{StaticResource SectionHeader}" DockPanel.Dock="Left"/>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                                <Button Content="↻ Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{StaticResource AccentCyan}" Margin="0,0,8,0"/>
                                <Button Content="Clear All" Command="{Binding ClearClientsCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{StaticResource AccentRed}"/>
                            </StackPanel>
                        </DockPanel>
                        <UniformGrid Columns="3" Margin="0,0,0,8">
                            <Border CornerRadius="6" Padding="10,8" Margin="0,0,4,0" Background="#11111B"><StackPanel Orientation="Horizontal"><Ellipse Width="8" Height="8" Fill="{Binding DhcpColor}" Margin="0,0,6,0"/><TextBlock Text="DHCP" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="12"/><TextBlock Text="{Binding DhcpDetail}" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="8,0,0,0"/></StackPanel></Border>
                            <Border CornerRadius="6" Padding="10,8" Margin="2,0" Background="#11111B"><StackPanel Orientation="Horizontal"><Ellipse Width="8" Height="8" Fill="{Binding TftpColor}" Margin="0,0,6,0"/><TextBlock Text="TFTP" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="12"/><TextBlock Text="{Binding TftpDetail}" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="8,0,0,0"/></StackPanel></Border>
                            <Border CornerRadius="6" Padding="10,8" Margin="4,0,0,0" Background="#11111B"><StackPanel Orientation="Horizontal"><Ellipse Width="8" Height="8" Fill="{Binding ApiColor}" Margin="0,0,6,0"/><TextBlock Text="API" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="12"/><TextBlock Text="{Binding ApiDetail}" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="8,0,0,0"/></StackPanel></Border>
                        </UniformGrid>
                    </StackPanel></Border>
                    <Border Style="{StaticResource CardStyle}"><StackPanel>
                        <TextBlock Text="{Binding ClientCountText}" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,8"/>
                        <Grid Margin="12,0,12,4"><Grid.ColumnDefinitions><ColumnDefinition Width="20"/><ColumnDefinition Width="140"/><ColumnDefinition Width="110"/><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/><ColumnDefinition Width="55"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="MAC Address" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="IP Address" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="3" Text="Hostname" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="4" Text="Current Step" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="5" Text="Progress" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="6" Text="Last Seen" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="SemiBold"/>
                        </Grid>
                        <Border Background="#11111B" CornerRadius="4" MaxHeight="500"><ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Clients}"><ItemsControl.ItemTemplate><DataTemplate>
                                <Border Padding="12,8" Margin="0,1" CornerRadius="3" Style="{StaticResource HoverRow}">
                                    <Border.InputBindings><MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.SelectClientCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}"/></Border.InputBindings>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="20"/><ColumnDefinition Width="140"/><ColumnDefinition Width="110"/><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/><ColumnDefinition Width="55"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                        <Ellipse Grid.Column="0" Width="10" Height="10" HorizontalAlignment="Left"><Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="{StaticResource TextMuted}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="completed"><Setter Property="Fill" Value="{StaticResource AccentGreen}"/></DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="pipeline_step"><Setter Property="Fill" Value="{StaticResource AccentBlue}"/></DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="pipeline_start"><Setter Property="Fill" Value="{StaticResource AccentCyan}"/></DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="winpe_start"><Setter Property="Fill" Value="{StaticResource AccentYellow}"/></DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="failed"><Setter Property="Fill" Value="{StaticResource AccentRed}"/></DataTrigger>
                                            </Style.Triggers>
                                        </Style></Ellipse.Style></Ellipse>
                                        <TextBlock Grid.Column="1" Text="{Binding Mac}" Foreground="{StaticResource AccentCyan}" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Ip}" Foreground="{StaticResource TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Hostname}" Foreground="{StaticResource TextPrimary}" FontSize="11" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="4" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding CurrentStep}" Foreground="{StaticResource TextPrimary}" FontSize="11" Margin="0,0,0,2"/>
                                            <Border Background="#313244" CornerRadius="3" Height="6"><Border CornerRadius="3" HorizontalAlignment="Left"><Border.Style><Style TargetType="Border"><Setter Property="Background" Value="{StaticResource AccentBlue}"/><Setter Property="Width" Value="0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="completed"><Setter Property="Background" Value="{StaticResource AccentGreen}"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="failed"><Setter Property="Background" Value="{StaticResource AccentRed}"/></DataTrigger>
                                                </Style.Triggers>
                                            </Style></Border.Style></Border></Border>
                                        </StackPanel>
                                        <TextBlock Grid.Column="5" Text="{Binding Progress, StringFormat='{}{0}%'}" Foreground="{StaticResource AccentBlue}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="6" Text="{Binding LastSeen}" Foreground="{StaticResource TextMuted}" FontSize="10" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                        </ScrollViewer></Border>
                    </StackPanel></Border>
                    <Border Style="{StaticResource CardStyle}" Visibility="{Binding SelectedClient, Converter={StaticResource NullToVisibilityConverter}}"><StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}"><Run Text="Events — "/><Run Text="{Binding SelectedClient.Mac, Mode=OneWay}" Foreground="{StaticResource AccentCyan}"/></TextBlock>
                        <Border Background="#11111B" CornerRadius="4" MaxHeight="200"><ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding SelectedClientEvents}"><ItemsControl.ItemTemplate><DataTemplate>
                                <TextBlock FontFamily="Consolas" FontSize="11" Padding="6,2" TextWrapping="Wrap">
                                    <Run Text="{Binding Time, Mode=OneWay}" Foreground="{StaticResource TextMuted}"/><Run Text=" "/><Run Text="{Binding Event, Mode=OneWay}" Foreground="{StaticResource AccentYellow}"/><Run Text=" "/><Run Text="{Binding Detail, Mode=OneWay}" Foreground="{StaticResource TextPrimary}"/>
                                </TextBlock>
                            </DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                        </ScrollViewer></Border>
                    </StackPanel></Border>
                </StackPanel>
            </ScrollViewer>

            <!-- SERVICES PAGE with embedded logs -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16" DataContext="{Binding Services}"
                          Visibility="{Binding DataContext.IsServicesPage, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <Border Style="{StaticResource CardStyle}"><StackPanel><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0"><StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Ellipse Width="10" Height="10" Margin="0,0,8,0"><Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="{StaticResource AccentRed}"/><Style.Triggers><DataTrigger Binding="{Binding ApiServerRunning}" Value="True"><Setter Property="Fill" Value="{StaticResource AccentGreen}"/></DataTrigger></Style.Triggers></Style></Ellipse.Style></Ellipse>
                            <TextBlock Text="API Server" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel><TextBlock Foreground="{StaticResource TextMuted}" FontSize="11" Margin="18,0,0,0"><Run Text="Port 8000 · "/><Run Text="{Binding ApiServerStatus, Mode=OneWay}"/></TextBlock></StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="▶ Start" Command="{Binding StartApiServerCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Background="{StaticResource AccentGreen}" Foreground="Black" Margin="0,0,6,0" Padding="12,4" IsEnabled="{Binding ApiServerStopped}"/>
                            <Button Content="■ Stop" Command="{Binding StopApiServerCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Background="{StaticResource AccentRed}" Foreground="Black" Padding="12,4" IsEnabled="{Binding ApiServerRunning}"/>
                        </StackPanel>
                    </Grid></StackPanel></Border>
                    <Border Style="{StaticResource CardStyle}"><StackPanel><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0"><StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Ellipse Width="10" Height="10" Margin="0,0,8,0"><Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="{StaticResource AccentRed}"/><Style.Triggers><DataTrigger Binding="{Binding DhcpServerRunning}" Value="True"><Setter Property="Fill" Value="{StaticResource AccentGreen}"/></DataTrigger></Style.Triggers></Style></Ellipse.Style></Ellipse>
                            <TextBlock Text="DHCP Server" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel><TextBlock Foreground="{StaticResource TextMuted}" FontSize="11" Margin="18,0,0,0"><Run Text="Ports 67/60/4011 · "/><Run Text="{Binding DhcpServerStatus, Mode=OneWay}"/></TextBlock></StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="▶ Start" Command="{Binding StartDhcpServerCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Background="{StaticResource AccentGreen}" Foreground="Black" Margin="0,0,6,0" Padding="12,4" IsEnabled="{Binding DhcpServerStopped}"/>
                            <Button Content="■ Stop" Command="{Binding StopDhcpServerCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Background="{StaticResource AccentRed}" Foreground="Black" Padding="12,4" IsEnabled="{Binding DhcpServerRunning}"/>
                        </StackPanel>
                    </Grid>
                    <Border Background="#11111B" CornerRadius="4" MaxHeight="180" Margin="0,8,0,0"><ScrollViewer VerticalScrollBarVisibility="Auto"><ItemsControl ItemsSource="{Binding DhcpLog}"><ItemsControl.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="10" Padding="6,1" Foreground="{StaticResource TextSecondary}" TextWrapping="NoWrap"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></ScrollViewer></Border>
                    </StackPanel></Border>
                    <Border Style="{StaticResource CardStyle}"><StackPanel><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0"><StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Ellipse Width="10" Height="10" Margin="0,0,8,0"><Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="{StaticResource AccentRed}"/><Style.Triggers><DataTrigger Binding="{Binding TftpServerRunning}" Value="True"><Setter Property="Fill" Value="{StaticResource AccentGreen}"/></DataTrigger></Style.Triggers></Style></Ellipse.Style></Ellipse>
                            <TextBlock Text="TFTP Server" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel><TextBlock Foreground="{StaticResource TextMuted}" FontSize="11" Margin="18,0,0,0"><Run Text="Ports 69/60 · "/><Run Text="{Binding TftpServerStatus, Mode=OneWay}"/></TextBlock></StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="▶ Start" Command="{Binding StartTftpServerCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Background="{StaticResource AccentGreen}" Foreground="Black" Margin="0,0,6,0" Padding="12,4" IsEnabled="{Binding TftpServerStopped}"/>
                            <Button Content="■ Stop" Command="{Binding StopTftpServerCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Background="{StaticResource AccentRed}" Foreground="Black" Padding="12,4" IsEnabled="{Binding TftpServerRunning}"/>
                        </StackPanel>
                    </Grid>
                    <Border Background="#11111B" CornerRadius="4" MaxHeight="180" Margin="0,8,0,0"><ScrollViewer VerticalScrollBarVisibility="Auto"><ItemsControl ItemsSource="{Binding TftpLog}"><ItemsControl.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="10" Padding="6,1" Foreground="{StaticResource TextSecondary}" TextWrapping="NoWrap"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></ScrollViewer></Border>
                    </StackPanel></Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ENHANCED STATUS BAR -->
            <Border Grid.Row="2" Background="#181825" BorderBrush="#313244" BorderThickness="0,1,0,0" Padding="12,0">
                <DockPanel>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextMuted}" FontSize="11" VerticalAlignment="Center" DockPanel.Dock="Left"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ActiveDeployCount, StringFormat='Deploying: {0}'}" Foreground="{StaticResource AccentCyan}" FontSize="10" Margin="0,0,16,0" Visibility="{Binding ActiveDeployCount, Converter={StaticResource StringToVisibilityConverter}}"/>
                        <TextBlock Text="API :8000" Foreground="{StaticResource TextMuted}" FontSize="10" Margin="0,0,12,0"/>
                        <TextBlock Text="DHCP :67" Foreground="{StaticResource TextMuted}" FontSize="10" Margin="0,0,12,0"/>
                        <TextBlock Text="TFTP :69" Foreground="{StaticResource TextMuted}" FontSize="10"/>
                        <ProgressBar Width="60" Height="3" IsIndeterminate="{Binding IsLoading}" Foreground="{StaticResource AccentBlue}" Background="Transparent" Margin="12,0,0,0" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
