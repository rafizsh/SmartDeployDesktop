<Window x:Class="SmartDeployDesktop.Views.StepCatalogPicker"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SmartDeployDesktop.ViewModels"
        xmlns:svc="clr-namespace:SmartDeployDesktop.Services"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Add Step" Width="945" Height="690" MinWidth="780" MinHeight="555"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BgBase}"
        TextElement.Foreground="{StaticResource TextPrimary}" FontFamily="Segoe UI"
        FontSize="14">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header + search -->
            <RowDefinition Height="Auto"/>  <!-- Category tabs -->
            <RowDefinition Height="*"/>     <!-- Step list -->
            <RowDefinition Height="Auto"/>  <!-- Button bar -->
        </Grid.RowDefinitions>

        <!-- Header + search -->
        <Border Grid.Row="0" Background="{StaticResource BgSurface}" Padding="16,12" BorderBrush="{StaticResource BgOverlay}" BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock Text="📚 Step Catalog" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AccentYellow}" VerticalAlignment="Center"/>
                <TextBox DockPanel.Dock="Right" Width="300" Margin="16,0,0,0"
                         materialDesign:HintAssist.Hint="Search steps..."
                         x:Name="SearchBox" TextChanged="SearchBox_TextChanged"/>
            </DockPanel>
        </Border>

        <!-- Category filter chips -->
        <Border Grid.Row="1" Background="{StaticResource BgSurface}" Padding="16,8" BorderBrush="{StaticResource BgOverlay}" BorderThickness="0,0,0,1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="CategoryChips">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Name}" Tag="{Binding Name}"
                                    Click="CategoryChip_Click"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="{StaticResource AccentCyan}"
                                    Padding="14,4" Margin="0,0,6,0">
                                <Button.Background>
                                    <SolidColorBrush Color="#252537"/>
                                </Button.Background>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Step list (filtered) -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="12">
            <ItemsControl x:Name="StepList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type svc:StepCatalogEntryDto}">
                        <Border Padding="14,10" Margin="2" CornerRadius="4"
                                Background="{StaticResource BgSurface}"
                                Cursor="Hand"
                                MouseLeftButtonDown="StepEntry_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="15" Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextMuted}" FontSize="13" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="1" Background="{StaticResource BgOverlay}" CornerRadius="3" Padding="8,3" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Category}" Foreground="{StaticResource AccentMauve}" FontSize="12" FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Button bar -->
        <Border Grid.Row="3" Background="{StaticResource BgSurface}" Padding="16,10" BorderBrush="{StaticResource BgOverlay}" BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock x:Name="SelectedLabel" Text="No step selected" Foreground="{StaticResource TextMuted}" FontSize="13" VerticalAlignment="Center"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Click="CancelButton_Click"
                            Style="{StaticResource MaterialDesignFlatButton}" Foreground="{StaticResource TextSecondary}"
                            Padding="16,4" Margin="0,0,8,0"/>
                    <Button Content="Add Step" x:Name="AddButton" Click="AddButton_Click"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="{StaticResource AccentGreen}" Foreground="Black"
                            Padding="20,4" IsEnabled="False"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
