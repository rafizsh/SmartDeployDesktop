<Window x:Class="SmartDeployDesktop.Views.TaskSequenceEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SmartDeployDesktop.ViewModels"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Task Sequence Editor" Width="1200" Height="780" MinWidth="1000" MinHeight="600"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BgBase}"
        TextElement.Foreground="{StaticResource TextPrimary}" FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="EditorRow" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#252537"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SelectedRow" TargetType="Border" BasedOn="{StaticResource EditorRow}">
            <Setter Property="Background" Value="#313244"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="Auto"/>  <!-- Header fields -->
            <RowDefinition Height="*"/>     <!-- Main editor area -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ============================================================= -->
        <!-- TOOLBAR                                                        -->
        <!-- ============================================================= -->
        <Border Grid.Row="0" Background="{StaticResource BgSurface}" Padding="16,10" BorderBrush="{StaticResource BgOverlay}" BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock Text="📋 Task Sequence Editor" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentYellow}" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button Content="📋 Duplicate" Command="{Binding DuplicateCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}" Foreground="{StaticResource AccentMauve}"
                            Margin="0,0,6,0"/>
                    <Button Content="⬇ Import" Command="{Binding ImportCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}" Foreground="{StaticResource AccentCyan}"
                            Margin="0,0,6,0"/>
                    <Button Content="⬆ Export" Command="{Binding ExportCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}" Foreground="{StaticResource AccentGreen}"
                            Margin="0,0,12,0"/>
                    <Button Content="Close" Click="CloseButton_Click"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="{StaticResource AccentBlue}" Foreground="Black" Padding="16,4"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ============================================================= -->
        <!-- HEADER FIELDS                                                  -->
        <!-- ============================================================= -->
        <Border Grid.Row="1" Background="{StaticResource BgSurface}" Padding="16,12" BorderBrush="{StaticResource BgOverlay}" BorderThickness="0,0,0,1">
            <UniformGrid Columns="4">
                <StackPanel Margin="0,0,8,0">
                    <TextBlock Text="Name" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, Delay=300}"/>
                </StackPanel>
                <StackPanel Margin="4,0">
                    <TextBlock Text="OS Version" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding OsVersion, UpdateSourceTrigger=PropertyChanged, Delay=300}"/>
                </StackPanel>
                <StackPanel Margin="4,0">
                    <TextBlock Text="Architecture" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding ArchitectureOptions}" SelectedItem="{Binding Architecture}"/>
                </StackPanel>
                <StackPanel Margin="8,0,0,0">
                    <TextBlock Text="Description" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged, Delay=300}"/>
                </StackPanel>
            </UniformGrid>
        </Border>

        <!-- ============================================================= -->
        <!-- MAIN: Steps | Parameter Editor | Variables (tabs)              -->
        <!-- ============================================================= -->
        <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0" Margin="0">
            <!-- ========================================================= -->
            <!-- TAB 1: STEPS                                               -->
            <!-- ========================================================= -->
            <TabItem Header="Steps">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="400" MinWidth="320"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ============================================== -->
                    <!-- LEFT: ordered step list                        -->
                    <!-- ============================================== -->
                    <Border Grid.Column="0" Background="{StaticResource BgSurface}" BorderBrush="{StaticResource BgOverlay}" BorderThickness="0,0,1,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Padding="12,10" Background="{StaticResource BgBase}">
                                <DockPanel>
                                    <TextBlock Text="Steps" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                    <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource TextMuted}" FontSize="11" VerticalAlignment="Center">
                                        <Run Text="{Binding Steps.Count, Mode=OneWay}"/>
                                        <Run Text=" total"/>
                                    </TextBlock>
                                </DockPanel>
                            </Border>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="4">
                                <ItemsControl ItemsSource="{Binding Steps}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:TaskStepViewModel}">
                                            <Border Padding="8,8" Margin="2" CornerRadius="4"
                                                    MouseLeftButtonDown="StepRow_Click"
                                                    BorderThickness="1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                        <Setter Property="Cursor" Value="Hand"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#252537"/>
                                                            </Trigger>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Background" Value="#313244"/>
                                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>  <!-- Order # -->
                                                        <ColumnDefinition Width="Auto"/>  <!-- Enabled checkbox -->
                                                        <ColumnDefinition Width="*"/>     <!-- Name + type -->
                                                        <ColumnDefinition Width="Auto"/>  <!-- Up/Down/Delete -->
                                                    </Grid.ColumnDefinitions>

                                                    <Border Grid.Column="0" Width="26" Height="26" CornerRadius="13"
                                                            Background="{StaticResource BgOverlay}" Margin="0,0,8,0">
                                                        <TextBlock Text="{Binding Order}" Foreground="{StaticResource AccentCyan}"
                                                                   FontWeight="Bold" FontSize="12"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>

                                                    <CheckBox Grid.Column="1" IsChecked="{Binding Enabled}" VerticalAlignment="Center" Margin="0,0,8,0"
                                                              ToolTip="Enable or disable this step"/>

                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" FontSize="13"/>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Category}" Foreground="{StaticResource AccentMauve}" FontSize="10" Margin="0,2,6,0"/>
                                                            <TextBlock Text="{Binding Type}" Foreground="{StaticResource TextMuted}" FontSize="10" Margin="0,2,0,0"/>
                                                            <TextBlock Text=" • with condition" Foreground="{StaticResource AccentYellow}" FontSize="10" Margin="4,2,0,0"
                                                                       Visibility="{Binding HasCondition, Converter={StaticResource BoolToVis}}"/>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Button Content="▲" Command="{Binding DataContext.MoveStepUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource MaterialDesignFlatButton}"
                                                                Foreground="{StaticResource TextSecondary}"
                                                                Width="26" Height="26" Padding="0" FontSize="10" ToolTip="Move up"/>
                                                        <Button Content="▼" Command="{Binding DataContext.MoveStepDownCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource MaterialDesignFlatButton}"
                                                                Foreground="{StaticResource TextSecondary}"
                                                                Width="26" Height="26" Padding="0" FontSize="10" ToolTip="Move down"/>
                                                        <Button Content="✕" Command="{Binding DataContext.DeleteStepCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource MaterialDesignFlatButton}"
                                                                Foreground="{StaticResource AccentRed}"
                                                                Width="26" Height="26" Padding="0" ToolTip="Delete step"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <Border Grid.Row="2" Padding="12,10" Background="{StaticResource BgBase}" BorderBrush="{StaticResource BgOverlay}" BorderThickness="0,1,0,0">
                                <Button Content="➕ Add Step From Catalog" Click="AddStepButton_Click"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Background="{StaticResource AccentGreen}" Foreground="Black"
                                        HorizontalAlignment="Stretch" Padding="12,6"/>
                            </Border>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="{StaticResource BgOverlay}"/>

                    <!-- ============================================== -->
                    <!-- RIGHT: parameter editor for selected step      -->
                    <!-- ============================================== -->
                    <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" Padding="16"
                                  DataContext="{Binding SelectedStep}">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>
                        <StackPanel>
                            <!-- Step header -->
                            <Border Background="{StaticResource BgSurface}" CornerRadius="4" Padding="14,12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Step Settings" Foreground="{StaticResource AccentYellow}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10"/>
                                    <UniformGrid Columns="2">
                                        <StackPanel Margin="0,0,8,8">
                                            <TextBlock Text="Name" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, Delay=300}"/>
                                        </StackPanel>
                                        <StackPanel Margin="8,0,0,8">
                                            <TextBlock Text="Type" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Text="{Binding Type}" IsReadOnly="True" Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                    </UniformGrid>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <CheckBox Content="Enabled" IsChecked="{Binding Enabled}" Margin="0,0,20,0" Foreground="{StaticResource TextPrimary}"/>
                                        <CheckBox Content="Continue on error" IsChecked="{Binding ContinueOnError}" Foreground="{StaticResource TextPrimary}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Condition builder -->
                            <Border Background="{StaticResource BgSurface}" CornerRadius="4" Padding="14,12" Margin="0,0,0,12">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,8">
                                        <TextBlock Text="Condition" Foreground="{StaticResource AccentYellow}" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                        <CheckBox DockPanel.Dock="Right" HorizontalAlignment="Right" Content="Has condition"
                                                  IsChecked="{Binding HasCondition}" Foreground="{StaticResource TextPrimary}"/>
                                    </DockPanel>
                                    <StackPanel Visibility="{Binding HasCondition, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="Run this step only when the condition below evaluates true."
                                                   Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Variable" Style="{StaticResource FieldLabel}"/>
                                                <ComboBox ItemsSource="{Binding GatherVariables}"
                                                          SelectedValue="{Binding ConditionVariable}"
                                                          SelectedValuePath="Name"
                                                          DisplayMemberPath="Name"
                                                          IsEditable="True" IsTextSearchEnabled="True"
                                                          Text="{Binding ConditionVariable, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Operator" Style="{StaticResource FieldLabel}"/>
                                                <ComboBox ItemsSource="{Binding ConditionOperators}"
                                                          SelectedValue="{Binding ConditionOperator}"
                                                          SelectedValuePath="Id"
                                                          DisplayMemberPath="Display"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="4">
                                                <TextBlock Text="Value" Style="{StaticResource FieldLabel}"/>
                                                <TextBox Text="{Binding ConditionValue, UpdateSourceTrigger=PropertyChanged, Delay=300}"/>
                                            </StackPanel>
                                        </Grid>
                                        <CheckBox Content="Negate (run when condition is false)" IsChecked="{Binding ConditionNegate}"
                                                  Foreground="{StaticResource TextPrimary}" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Parameters - typed editor per parameter -->
                            <Border Background="{StaticResource BgSurface}" CornerRadius="4" Padding="14,12">
                                <StackPanel>
                                    <TextBlock Text="Parameters" Foreground="{StaticResource AccentYellow}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10"/>
                                    <ItemsControl ItemsSource="{Binding Parameters}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:ParameterEditorViewModel}">
                                                <StackPanel Margin="0,0,0,10">
                                                    <TextBlock Text="{Binding DisplayLabel}" Style="{StaticResource FieldLabel}"/>
                                                    <!-- Bool -->
                                                    <CheckBox IsChecked="{Binding BoolValue}" Foreground="{StaticResource TextPrimary}"
                                                              Visibility="{Binding IsBool, Converter={StaticResource BoolToVis}}"
                                                              Content="{Binding DisplayLabel}"/>
                                                    <!-- Int -->
                                                    <TextBox Text="{Binding IntValue, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                                                             Visibility="{Binding IsInt, Converter={StaticResource BoolToVis}}"/>
                                                    <!-- List (newline-separated) -->
                                                    <TextBox Text="{Binding ListValue, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                                                             Visibility="{Binding IsList, Converter={StaticResource BoolToVis}}"
                                                             AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" VerticalScrollBarVisibility="Auto"
                                                             ToolTip="One entry per line"/>
                                                    <!-- String -->
                                                    <TextBox Text="{Binding StringValue, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                                                             Visibility="{Binding IsString, Converter={StaticResource BoolToVis}}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Empty state when no step is selected -->
                    <TextBlock Grid.Column="2" Text="Select a step on the left, or add one from the catalog."
                               Foreground="{StaticResource TextMuted}" FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedStep}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </TabItem>

            <!-- ========================================================= -->
            <!-- TAB 2: VARIABLES                                           -->
            <!-- ========================================================= -->
            <TabItem Header="Variables">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel>
                        <Border Background="{StaticResource BgSurface}" CornerRadius="4" Padding="14,12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Sequence Variables" Foreground="{StaticResource AccentYellow}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,4"/>
                                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,10">
                                    Define variables that can be referenced by step conditions and parameters. Variables defined here are overridden by values produced by Gather steps at runtime.
                                </TextBlock>
                                <Button Content="➕ Add Variable" Command="{Binding AddVariableCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Background="{StaticResource AccentGreen}" Foreground="Black"
                                        HorizontalAlignment="Left" Padding="12,4"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource BgSurface}" CornerRadius="4" Padding="14,12">
                            <ItemsControl ItemsSource="{Binding Variables}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:VariableEntryViewModel}">
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Text="{Binding Key, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                                                     materialDesign:HintAssist.Hint="Variable name"/>
                                            <TextBox Grid.Column="2" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                                                     materialDesign:HintAssist.Hint="Default value"/>
                                            <Button Grid.Column="4" Content="✕"
                                                    Command="{Binding DataContext.DeleteVariableCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource MaterialDesignFlatButton}"
                                                    Foreground="{StaticResource AccentRed}" Width="32" Height="32" Padding="0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- ============================================================= -->
        <!-- STATUS BAR                                                     -->
        <!-- ============================================================= -->
        <Border Grid.Row="3" Background="{StaticResource BgSurface}" Padding="16,6" BorderBrush="{StaticResource BgOverlay}" BorderThickness="0,1,0,0">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource AccentGreen}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasUnsavedChanges}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource AccentYellow}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                           Foreground="{StaticResource TextMuted}" FontSize="11" VerticalAlignment="Center">
                    <Run Text="Auto-save enabled · "/>
                    <Run Text="{Binding SequenceId, StringFormat='ID: {0}', Mode=OneWay}"/>
                </TextBlock>
            </DockPanel>
        </Border>
    </Grid>
</Window>
